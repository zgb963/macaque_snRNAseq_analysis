/*
 * nextflow.config
 * Config for run_cellranger_count.nf
 * config file isn't required but best practice! See Nextflow best practices https://carpentries-incubator.github.io/Pipeline_Training_with_Nextflow/07-Nextflow_Best_Practice/index.html
 */

// ---------------------- Default parameters ----------------------
// Like params.* set in script
params {
    hpc_user       = System.getenv('USER')
    pi_data_dir    = "/pi/raw_data/macaque"
    cellranger_bin = "$HOME/yard/apps/cellranger-7.2.0"
    workdir        = "$HOME/macaque_snRNAseq"
    outdir         = "${params.workdir}/results"

    genome_dir     = "${params.workdir}/ens_mmul10_genome_files"
    gtf_raw        = "${params.genome_dir}/Macaca_mulatta.Mmul_10.113.gtf"
    fasta          = "${params.genome_dir}/Macaca_mulatta.Mmul_10.dna.toplevel.fa"
    reference_name = "ens_mmul10_reference"
}

// ---------------------- Executor ----------------------
executor {
    name = 'lsf'
    // limit submitted jobs so don't flood LSF schedule
    queueSize = 50
    submitRateLimit = '10/1min'
}

// ---------------------- Process defaults ----------------------
// per-process cpus/memory/time/queue already set in script,
// this provides fallback defaults + retry if jobs fail/crash
process {
    executor = 'lsf'
    cpus     = 2
    memory   = '4 GB'
    time     = '2h'
    queue    = 'short'

    errorStrategy = { task.exitStatus in [130, 143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
}

// ---------------------- Execution reports ----------------------
// Helpful for debugging resource usage / time on LSF
def timestamp = new Date().format('yyyy-MM-dd_HH-mm-ss')

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_reports/report_${timestamp}.html"
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_reports/trace_${timestamp}.txt"
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_reports/timeline_${timestamp}.html"
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_reports/dag_${timestamp}.html"
}

// ---------------------- Profiles ----------------------
profiles {
    lsf {
        process.executor  = 'lsf'
        executor.name      = 'lsf'
    }

    // Local test/dev run with a small subset — override sample list via a
    // separate test script/params, or just run FASTQC/MKGTF steps locally
    test {
        process.executor = 'local'
        process.cpus     = 2
        process.memory   = '4 GB'
        process.time     = '1h'
    }

    // If containerize cellranger/fastqc/multiqc later
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}


cleanup = false  // set true once you've confirmed outputs correct, to auto-clear work/